OMNISIGHT_SECRET=change-me-to-a-long-random-string
PORT=3000

# Encryption is on by default. Plaintext secrets require both
# OMNISIGHT_ENCRYPT=0 and this explicit unsafe opt-in.
OMNISIGHT_ALLOW_PLAINTEXT_SECRETS=0

# Set to 1 behind a TLS-terminating reverse proxy to reject/redirect plain HTTP.
OMNISIGHT_REQUIRE_HTTPS=0

# Set to 1 to reject non-TLS agent API traffic. Inherits OMNISIGHT_REQUIRE_HTTPS when enabled.
OMNISIGHT_REQUIRE_AGENT_TLS=0

# Set to 1 to store/display hashed IP identifiers in logs and sessions.
OMNISIGHT_REDACT_IPS=0

# Optional per-minute limits; leave unset to use built-in defaults.
# OMNISIGHT_API_RATE_LIMIT=300
# OMNISIGHT_WRITE_RATE_LIMIT=120
# OMNISIGHT_AGENT_RATE_LIMIT=600
